milestone.schema.json

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ei.dev/schemas/v0/milestone.schema.json",
  "title": "Milestone",
  "description": "Defines objective proof points for skill mastery.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "milestone_id",
    "skill_id",
    "statement",
    "observable_behavior",
    "decision_type",
    "pass_threshold",
    "evidence_modes",
    "status",
    "version"
  ],
  "properties": {
    "milestone_id": {
      "type": "string",
      "pattern": "^ms_[a-zA-Z0-9._-]+$"
    },
    "skill_id": {
      "type": "string",
      "pattern": "^skill_[a-zA-Z0-9._-]+$"
    },
    "statement": {
      "type": "string",
      "description": "Should complete the phrase: Learner can..."
    },
    "observable_behavior": {
      "type": "string"
    },
    "decision_type": {
      "type": "string",
      "enum": ["binary"],
      "description": "v0 is binary only: demonstrated or not_yet."
    },
    "pass_threshold": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_text"],
      "properties": {
        "rule_text": {
          "type": "string",
          "description": "Human-readable pass rule."
        },
        "minimum_score": {
          "type": ["number", "null"]
        },
        "rubric_reference": {
          "type": ["string", "null"]
        }
      }
    },
    "evidence_modes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "artifact",
          "oral_explanation",
          "written_explanation",
          "demonstration",
          "observation",
          "peer_feedback",
          "facilitator_feedback",
          "quiz",
          "project",
          "simulation",
          "reflection",
          "portfolio"
        ]
      },
      "uniqueItems": true
    },
    "allowed_variations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit room for multiple valid routes to proof."
    },
    "four_box_criteria": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "accuracy": { "type": "boolean", "default": true },
        "reasoning": { "type": "boolean", "default": true },
        "application": { "type": "boolean", "default": true },
        "representation": { "type": "boolean", "default": true }
      }
    },
    "prerequisite_milestone_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^ms_[a-zA-Z0-9._-]+$"
      },
      "uniqueItems": true
    },
    "portability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "portable": { "type": "boolean", "default": true },
        "portability_notes": { "type": ["string", "null"] }
      }
    },
    "version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "approved", "deprecated"]
    }
  }
}


