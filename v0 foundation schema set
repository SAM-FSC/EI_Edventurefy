design-rules.md)
1. Preserve source truth.
2. Translate, do not erase.
3. Allow many-to-one mappings.
4. Multiple valid evidence modes are first-class — self, peer, facilitator, project, observation, Challenge Day, etc. No-tech is native.
5. Mastery can surface on non-linear or unexpected paths — the Skills Map supports this.
6. Binary mastery only — keeps decisions clear and portable.
7. Designed for life-long skill acquisition, not test-and-forget or pure job placement.
8. Foundation first — Edventurefy/quests plug in on top.


repository.schema.json

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ei.dev/schemas/v0/repository.schema.json",
  "title": "Repository Item",
  "description": "Stores source framework, standard, objective, version, provenance, jurisdiction, subject, and age band.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "repository_item_id",
    "source_framework",
    "source_type",
    "source_text",
    "source_version",
    "subject_domains",
    "age_bands",
    "jurisdictions",
    "status"
  ],
  "properties": {
    "repository_item_id": {
      "type": "string",
      "pattern": "^repo_[a-zA-Z0-9._-]+$"
    },
    "source_framework": {
      "type": "string",
      "enum": ["Common Core", "NGSS", "IB", "Oxford", "Other"]
    },
    "source_framework_other": {
      "type": ["string", "null"]
    },
    "source_type": {
      "type": "string",
      "enum": ["standard", "objective", "learning_goal", "content_excerpt", "competency", "other"]
    },
    "source_document_title": {
      "type": ["string", "null"]
    },
    "source_document_section": {
      "type": ["string", "null"]
    },
    "source_identifier": {
      "type": ["string", "null"],
      "description": "Original framework code or identifier, if any."
    },
    "source_text": {
      "type": "string",
      "minLength": 1
    },
    "source_plain_language_summary": {
      "type": ["string", "null"]
    },
    "source_version": {
      "type": "string"
    },
    "source_url": {
      "type": ["string", "null"],
      "format": "uri"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["import_method"],
      "properties": {
        "import_method": {
          "type": "string",
          "enum": ["manual", "bulk_import", "api", "derived_from_doc", "other"]
        },
        "imported_by": {
          "type": ["string", "null"]
        },
        "imported_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "notes": {
          "type": ["string", "null"]
        }
      }
    },
    "jurisdictions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "subject_domains": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "age_bands": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "grade_bands": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "language": {
      "type": "string",
      "default": "en"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "status": {
      "type": "string",
      "enum": ["draft", "review", "approved", "deprecated"]
    },
    "linked_skill_ids": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^skill_[a-zA-Z0-9._-]+$"
